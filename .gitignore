# Build artifacts
*.exe
*.test
*.out
/bin/
/dist/

# Editor / IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Go
/vendor/

# peersh dev artifacts
dev-cert.pem
dev-key.pem

# Mobile build artifacts (rebuilt from mobile-core/ via scripts/build-mobile-core.sh)
app/android/app/libs/peersh.aar
app/android/app/libs/peersh-sources.jar
app/ios/Frameworks/peersh.xcframework/

# Flutter build outputs (auto-managed; the project keeps its own .gitignore as well)
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies

# Local PSK secrets — never commit
/local/

# Local peersh-signaling SQLite state (generated when running server locally)
peersh-signaling.db
peersh-signaling.db-*

# Phase 5b: Firebase / FlutterFire generated config — project-specific.
# Android and Dart stubs are tracked; use git update-index --skip-worktree
# after replacing them locally with real project values.
app/ios/Runner/GoogleService-Info.plist
# .firebaserc holds the operator's project id; .firebaserc.example is the template.
firebase/.firebaserc

# Android release-signing config — operator-specific credentials. The
# example file is committed; the real one stays local.
app/android/key.properties
app/android/*.keystore
app/android/*.jks
