# Copy to local/peershd-build.env and fill in. local/ is gitignored, so
# the real values stay off-tree. See docs/deploy/self-hosting.md for an
# end-to-end walkthrough.

PEERSH_BUILD_FIREBASE_PROJECT_ID=your-project-id
PEERSH_BUILD_FIREBASE_API_KEY=AIzaSy-your-web-api-key
PEERSH_BUILD_FIREBASE_REGION=asia-northeast1
PEERSH_BUILD_SIGNALING_URL=wss://your-signaling-host/ws

# OAuth 2.0 "Desktop app" client. Google's docs explicitly state the
# secret of an Installed-app client "isn't actually treated as a
# secret"; embedding here is fine.
PEERSH_BUILD_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
PEERSH_BUILD_GOOGLE_CLIENT_SECRET=GOCSPX-...
