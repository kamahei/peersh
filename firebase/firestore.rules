rules_version = '2';

// Per-user isolation. A user can only read or write documents under
// their own /users/{uid}/... subtree. The peersh-signaling server uses
// the Firebase Admin SDK which bypasses these rules, so server-side
// reads / writes still work.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // The user document itself.
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }
      match /pairings/{pairingId} {
        allow read, write: if isOwner(userId);
      }
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
      // Wake events moved to Realtime Database in v2-A. See
      // database.rules.json. Firestore wake_requests rule is no
      // longer needed.
    }

    // ops/* is internal state owned by the Cloud Functions / signaling
    // server (budget-state, etc.). Admin SDK bypasses these rules; deny
    // all client access explicitly.
    match /ops/{doc=**} {
      allow read, write: if false;
    }

    // pairing_codes/* is short-lived state managed by the pairing Cloud
    // Functions (mintPairingCode / claimPairingCode). Admin-only.
    match /pairing_codes/{code} {
      allow read, write: if false;
    }

    // Catch-all: deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
